.tabs { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.tab { flex: 1; padding: 24rpx; text-align: center; background: #f0f0f0; border-radius: 16rpx; }
.tab.active { background: #0055BB; color: #fff; }
.field { margin-bottom: 24rpx; }
.label { display: block; margin-bottom: 8rpx; font-size: 26rpx; color: #666; }
input { padding: 24rpx; background: #f5f5f5; border-radius: 16rpx; }
.gender { display: flex; gap: 16rpx; }
.gender-btn { flex: 1; padding: 24rpx; text-align: center; background: #f5f5f5; border-radius: 16rpx; }
.gender-btn.active { background: #0055BB; color: #fff; }
.result { margin-top: 24rpx; background: #e8f4ff; }
.result-label { display: block; font-size: 24rpx; color: #666; margin-top: 16rpx; }
.result-value { font-size: 48rpx; font-weight: bold; color: #0055BB; }
.result-unit { font-size: 26rpx; color: #666; margin-left: 8rpx; }
