.quick-title { font-weight: bold; margin-bottom: 24rpx; }
.grid { display: flex; flex-wrap: wrap; gap: 24rpx; }
.grid-item {
  flex: 1;
  min-width: 180rpx;
  padding: 32rpx;
  background: #f0f4ff;
  border-radius: 24rpx;
  text-align: center;
}
.grid-label { font-size: 26rpx; font-weight: 600; color: #0055BB; }
.placeholder { color: #999; font-size: 26rpx; }

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid #eee;
  padding-bottom: env(safe-area-inset-bottom);
}
.nav-item { font-size: 24rpx; color: #999; }
.nav-center { color: #0055BB; font-weight: 600; }
