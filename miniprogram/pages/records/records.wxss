.input-wrap { position: relative; margin-bottom: 24rpx; }
.textarea {
  width: 100%;
  min-height: 280rpx;
  padding: 24rpx;
  padding-bottom: 100rpx;
  box-sizing: border-box;
  border: 1rpx solid #e0e0e0;
  border-radius: 16rpx;
  background: #fff;
}
.mic-btn {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #0055BB;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}
.mic-btn.recording { background: #e54; }

.result-card .field { margin-bottom: 24rpx; }
.field-label { font-weight: bold; color: #333; display: block; margin-bottom: 8rpx; }
.field-value { color: #666; font-size: 26rpx; white-space: pre-wrap; }
.actions { display: flex; gap: 24rpx; margin-top: 32rpx; }
.btn-secondary { flex: 1; background: #f5f5f5; color: #333; }
.btn-green { flex: 1; background: #0a6; color: #fff; }

.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 100rpx; background: #fff;
  display: flex; align-items: center; justify-content: space-around;
  border-top: 1rpx solid #eee;
  padding-bottom: env(safe-area-inset-bottom);
}
.nav-item { font-size: 24rpx; color: #999; }
.nav-active { color: #0055BB; font-weight: 600; }
.nav-center { color: #0055BB; font-weight: 600; }
.section-title { font-weight: bold; margin-bottom: 16rpx; }
.section-title.row { display: flex; justify-content: space-between; align-items: center; }
.link { color: #0055BB; font-size: 26rpx; }
.patient-card { display: flex; align-items: center; gap: 24rpx; padding: 24rpx; background: #f8fafc; border-radius: 16rpx; border: 1rpx solid #e2e8f0; }
.patient-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; background: #dbeafe; color: #0055BB; font-weight: bold; font-size: 32rpx; display: flex; align-items: center; justify-content: center; }
.patient-avatar.small { width: 64rpx; height: 64rpx; font-size: 28rpx; }
.patient-info { flex: 1; min-width: 0; }
.patient-name { font-weight: bold; color: #333; font-size: 30rpx; }
.tag { font-size: 22rpx; color: #0055BB; background: #dbeafe; padding: 4rpx 12rpx; border-radius: 20rpx; margin-left: 8rpx; font-weight: normal; }
.patient-meta { font-size: 24rpx; color: #666; display: block; margin-top: 8rpx; }

.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 100; display: flex; align-items: flex-end; }
.modal-panel { width: 100%; max-height: 70vh; background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 32rpx; padding-bottom: env(safe-area-inset-bottom); }
.modal-title { font-weight: bold; font-size: 34rpx; margin-bottom: 24rpx; }
.modal-list { max-height: 55vh; }
.modal-item { display: flex; align-items: center; gap: 24rpx; padding: 24rpx; border-radius: 16rpx; margin-bottom: 16rpx; background: #f5f5f5; }
.modal-item.active { background: #e8f4ff; border: 2rpx solid #0055BB; }
.modal-item-info { flex: 1; min-width: 0; }
.modal-item-name { font-weight: 600; color: #333; display: block; }
.modal-item-meta { font-size: 24rpx; color: #666; }
