.msg-list { flex: 1; height: 60vh; padding: 24rpx; }
.msg-row { margin-bottom: 24rpx; }
.msg-row.user { display: flex; justify-content: flex-end; }
.msg-row.ai { display: flex; justify-content: flex-start; }
.bubble {
  max-width: 75%;
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
}
.msg-row.user .bubble { background: #0055BB; color: #fff; border-bottom-right-radius: 4rpx; }
.msg-row.ai .bubble { background: #fff; color: #333; border: 1rpx solid #eee; border-bottom-left-radius: 4rpx; }

.suggestions { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 16rpx 24rpx; }
.chip {
  padding: 12rpx 24rpx;
  background: #f0f4ff;
  color: #0055BB;
  border-radius: 32rpx;
  font-size: 24rpx;
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
.input { flex: 1; padding: 24rpx; background: #f5f5f5; border-radius: 24rpx; }
.send-btn { background: #0055BB; color: #fff; padding: 24rpx 32rpx; border-radius: 24rpx; font-size: 28rpx; }

.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 100rpx; background: #fff;
  display: flex; align-items: center; justify-content: space-around;
  border-top: 1rpx solid #eee;
  padding-bottom: env(safe-area-inset-bottom);
}
.nav-item { font-size: 24rpx; color: #999; }
.nav-active { color: #0055BB; font-weight: 600; }
.nav-center { color: #0055BB; font-weight: 600; }
