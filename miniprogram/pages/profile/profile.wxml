<view class="container">
  <view class="section-title">Ai 大模型配置</view>
  <view class="card">
    <view class="row" bindtap="onSelectGlobal">
      <view class="row-main">
        <text class="row-title">全局默认模型</text>
        <text class="row-desc">未单独设置的功能均使用此模型</text>
        <text class="row-value">{{globalName || '未选择'}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view
      wx:for="{{moduleRows}}"
      wx:key="key"
      class="row row-sub"
      bindtap="onSelectModule"
      data-key="{{item.key}}"
    >
      <view class="row-main">
        <text class="row-title-sm">{{item.label}}</text>
        <text class="row-value-sm">{{item.display}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>
  <view class="card">
    <text class="hint">HIS / EMR 配置可在后端扩展</text>
  </view>

  <view class="bottom-nav">
    <navigator url="/pages/index/index" class="nav-item">首页</navigator>
    <navigator url="/pages/records/records" class="nav-item">病历</navigator>
    <navigator url="/pages/search/search" class="nav-item nav-center">搜索</navigator>
    <navigator url="/pages/qa/qa" class="nav-item">问答</navigator>
    <navigator url="/pages/profile/profile" class="nav-item nav-active">我的</navigator>
  </view>
</view>

<view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal">
  <view class="modal" catchtap="">
    <view class="modal-title">{{modalTitle}}</view>
    <scroll-view scroll-y class="modal-scroll">
      <view
        wx:if="{{pickTarget !== 'global'}}"
        class="modal-item modal-follow"
        bindtap="onFollowGlobal"
      >
        <text class="modal-item-name">跟随全局默认</text>
        <text class="modal-item-desc">{{globalName}}</text>
      </view>
      <view
        wx:for="{{models}}"
        wx:key="id"
        class="modal-item"
        data-id="{{item.id}}"
        bindtap="onChooseModel"
      >
        <text class="modal-item-name">{{item.name}}</text>
        <text class="modal-item-desc">{{item.description}}</text>
      </view>
    </scroll-view>
  </view>
</view>
