.container { padding: 24rpx 24rpx 140rpx; }
.section-title { font-size: 24rpx; color: #94a3b8; font-weight: 600; padding: 16rpx 8rpx 12rpx; }
.card { background: #fff; border-radius: 24rpx; padding: 8rpx 28rpx; margin-bottom: 24rpx; border: 1rpx solid #f1f5f9; }
.row { display: flex; align-items: center; padding: 28rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.row:last-child { border-bottom: none; }
.row-sub { padding: 24rpx 0; }
.row-main { flex: 1; min-width: 0; }
.row-title { display: block; font-weight: 600; font-size: 30rpx; }
.row-desc { display: block; font-size: 22rpx; color: #94a3b8; margin-top: 8rpx; }
.row-value { display: block; color: #0055BB; font-size: 26rpx; margin-top: 8rpx; }
.row-title-sm { display: block; font-size: 28rpx; font-weight: 600; color: #333; }
.row-value-sm { display: block; font-size: 24rpx; color: #64748b; margin-top: 6rpx; }
.arrow { color: #999; font-size: 36rpx; margin-left: 16rpx; flex-shrink: 0; }
.hint { font-size: 24rpx; color: #999; }

.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 100rpx; background: #fff;
  display: flex; align-items: center; justify-content: space-around;
  border-top: 1rpx solid #eee;
  padding-bottom: env(safe-area-inset-bottom);
}
.nav-item { font-size: 24rpx; color: #999; }
.nav-active { color: #0055BB; font-weight: 600; }
.nav-center { color: #0055BB; font-weight: 600; }

.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 100; display: flex; align-items: flex-end; }
.modal {
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}
.modal-title { font-weight: bold; margin-bottom: 24rpx; }
.modal-scroll { max-height: 55vh; }
.modal-follow { background: #fef3c7 !important; border: 2rpx solid #f59e0b !important; }
.modal-item {
  padding: 28rpx;
  margin-bottom: 16rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}
.modal-item.active { border-color: #0055BB; background: #f0f4ff; }
.modal-item-name { display: block; font-weight: 600; }
.modal-item-desc { font-size: 24rpx; color: #666; }
