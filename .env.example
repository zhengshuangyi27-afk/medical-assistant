# LLM keys (按实际使用的服务商配置)
# DASHSCOPE_API_KEY=
# OPENAI_API_KEY=

# 部署到 Vercel 时必填：前端构建会把该地址写进包内，请求发往此后端（Express）
# 勿带尾斜杠，例如 https://xxx.up.railway.app
# VITE_API_URL=

# Supabase（推荐配置：用户 ma_users、病历 medical_records、设置 user_settings 等均写入云端）
# 未配置时：用户与病历落本机 SQLite（server/data/*.sqlite）
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 登录鉴权（生产环境务必修改）
AUTH_SECRET=please-use-a-long-random-string-in-production

# 后端端口
# PORT=3001
